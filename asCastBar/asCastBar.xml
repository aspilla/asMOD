<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">

	<Frame name="ACBFrameTemplate" virtual="true" enableMouse="false" frameStrata="LOW" frameLevel="1000">
		<Size>
			<AbsDimension x="17" y="17"/>
		</Size>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentIcon" parentKey="icon"/>
			</Layer>
			<Layer level="OVERLAY">
				<Texture name="$parentBorder" file="Interface\Addons\asTargetCastBar\border.tga" parentKey="border">
					<Size>
						<AbsDimension x="17" y="17"/>
					</Size>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="0" y="0"/>
						</Anchor>
						<Anchor point="BOTTOMRIGHT">
							<Offset x="0" y="0"/>
						</Anchor>
					</Anchors>
					<TexCoords left="0.296875" right="0.5703125" top="0" bottom="0.515625"/>
				</Texture>	
			</Layer>
		</Layers>
	</Frame>
	<Texture name="asCastBarNotInteruptTemplate" virtual="true" atlas="RaidFrame-Hp-Fill">		
	</Texture>
	<Frame name="asCastIconFrameTemplate" virtual="true" enableMouse="false">		
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentIcon" parentKey="icon" setAllPoints="true"/>
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="7">
				<Texture name="$parentBorder" parentKey="border" setAllPoints="true" file="Interface\Addons\asCastbar\border.tga"/>
			</Layer>
		</Layers>
	</Frame>
	<Script file="asCastBar.lua"/>
</Ui>
