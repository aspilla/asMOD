<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\Blizzard_SharedXML\UI.xsd">
	<Frame name="asFirestarterTemplate" virtual="true" enableMouse="false" frameStrata="LOW">
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="icon" setAllPoints="true" />
			</Layer>
			<Layer level="ARTWORK" textureSubLevel="6">
				<Texture parentKey="border" setAllPoints="true" file="Interface\Addons\asFirestarter\border.tga"/>	
			</Layer>
			<Layer level="OVERLAY">
				<FontString name="$parentHealth" parentKey="health" justifyH="RIGHT"/>							
			</Layer>	
		</Layers>
	</Frame>	
</Ui>
